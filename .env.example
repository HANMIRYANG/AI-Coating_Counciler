# ───────────────────────────────────────────────────────────────
# AI Coating Council — Environment Variables
# ───────────────────────────────────────────────────────────────

# Database (Prisma)
#
# Local dev (docker compose Postgres): DATABASE_URL and DIRECT_URL can be the
# same connection string.
#
# Vercel + Neon production:
#   DATABASE_URL = Neon POOLED runtime URL (pgbouncer). Used by the app at
#                  runtime. Typically ends with `-pooler` host + `?sslmode=require`.
#   DIRECT_URL   = Neon DIRECT (non-pooled) URL. Used by `prisma migrate` /
#                  introspection only. Required because the pooled endpoint
#                  cannot run migrations.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_coating_council?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ai_coating_council?schema=public"

# ───────────────────────────────────────────────────────────────
# Original-file storage (Vercel Blob, Step 14)
# ───────────────────────────────────────────────────────────────
# Read-write token for the Vercel Blob store used by
#   POST /api/documents/blob/upload
# to store LARGE BINARY ORIGINALS (PDF/DOCX/etc.). Create a Blob store in the
# Vercel dashboard (PRIVATE access recommended) and paste its token here.
# If unset, the upload route returns 503 (the inline text/markdown intake is
# unaffected). Originals are stored only — no parsing/extraction/RAG yet.
BLOB_READ_WRITE_TOKEN=""

# ───────────────────────────────────────────────────────────────
# Provider API keys
# ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# ───────────────────────────────────────────────────────────────
# Per-role model overrides (RECOMMENDED)
# Each provider has a 4-role chain:
#   PRIMARY        — default workhorse
#   FALLBACK       — optional middle hop on 429 / quota pressure
#   FAST_FALLBACK  — cheapest / fastest, last resort
#   HIGH_ACCURACY  — used for high-risk coating prompts (fire / cert / etc.)
#
# resolveModelChain walks:
#   default        → [primary, fallback?, fastFallback]
#   high_accuracy  → [highAccuracy, primary, fallback?, fastFallback]
# Dedup preserves order.
# ───────────────────────────────────────────────────────────────

# OpenAI
OPENAI_PRIMARY_MODEL="gpt-5.5"
OPENAI_FALLBACK_MODEL="gpt-5.4"
OPENAI_FAST_FALLBACK_MODEL="gpt-5.4-mini"
OPENAI_HIGH_ACCURACY_MODEL="gpt-5.5"

# Anthropic
ANTHROPIC_PRIMARY_MODEL="claude-sonnet-4-6"
ANTHROPIC_FAST_FALLBACK_MODEL="claude-haiku-4-5"
ANTHROPIC_HIGH_ACCURACY_MODEL="claude-opus-4-8"

# Gemini
GEMINI_PRIMARY_MODEL="gemini-3.5-flash"
GEMINI_FAST_FALLBACK_MODEL="gemini-2.5-flash"
GEMINI_HIGH_ACCURACY_MODEL="gemini-2.5-flash"

# Legacy primary-only overrides (BACKWARD COMPATIBILITY).
# These only affect `primary` if the matching `*_PRIMARY_MODEL` is unset.
# They NEVER override highAccuracy / fallback / fastFallback.
# OPENAI_MODEL="gpt-5.5"
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# GEMINI_MODEL="gemini-3.5-flash"

# ───────────────────────────────────────────────────────────────
# Model policy — substring rejection of preview/experimental/latest.
# Keep all three false in production.
# ───────────────────────────────────────────────────────────────
ALLOW_PREVIEW_MODELS=false
ALLOW_EXPERIMENTAL_MODELS=false
# '*-latest' moving aliases drift silently. NOT recommended.
ALLOW_LATEST_MODELS=false

# Execution mode — true → mock providers, no real API calls
USE_MOCK_PROVIDERS=true

# Timeout policy (milliseconds)
PROVIDER_TIMEOUT_MS=90000
ROUND_TIMEOUT_MS=120000
SYNTHESIS_TIMEOUT_MS=90000
SESSION_TIMEOUT_MS=240000

# Once a round reaches its minimum successful-provider count (quorum), wait at
# most this long for the remaining providers before cancelling them and
# advancing. Keeps one slow/hung provider from holding the whole round to its
# full PROVIDER_TIMEOUT_MS. Providers that finish inside the window are still
# included.
ROUND_QUORUM_GRACE_MS=8000

# Retry policy
MAX_PROVIDER_RETRIES=1
RETRY_BASE_DELAY_MS=1200
RETRY_MAX_DELAY_MS=5000

# Minimum success thresholds
MIN_INITIAL_OPINIONS_FOR_MEETING=2
MIN_CRITIQUES_FOR_SYNTHESIS=2

# UI refresh
# Note: This is inlined into the client bundle at build time, so it must be
# prefixed with NEXT_PUBLIC_. Non-finite / non-positive values fall back to
# 1500ms in the UI. Error-retry cadence is derived (max(2x, 3000ms)).
NEXT_PUBLIC_POLLING_INTERVAL_MS=1500

# Safety
ENABLE_DOMAIN_SAFETY_GUARD=true
ENABLE_UNSAFE_PHRASE_DETECTION=true

# Mock provider delays — used only when USE_MOCK_PROVIDERS=true
MOCK_GEMINI_DELAY_MS=2500
MOCK_CLAUDE_DELAY_MS=3500
MOCK_OPENAI_DELAY_MS=4500

# Mock failure injection (leave empty to disable)
#   MOCK_FAIL_PROVIDER=gemini     → provider throws non-retryable error
#   MOCK_TIMEOUT_PROVIDER=claude  → provider exceeds PROVIDER_TIMEOUT_MS
#   MOCK_HANG_PROVIDER=openai     → provider never resolves (tests deadline safety)
MOCK_FAIL_PROVIDER=
MOCK_TIMEOUT_PROVIDER=
MOCK_HANG_PROVIDER=

# Session persistence mode.
#   memory (default) — in-process MemorySessionStore. Single-process dev / mock
#                      flow. Sessions are lost on restart.
#   prisma           — PrismaSessionStore. Persisted to PostgreSQL via
#                      DATABASE_URL above. Required for multi-worker /
#                      multi-process deployments. After flipping this on:
#                        docker compose up -d            # repo root
#                        cd apps/web && npx prisma migrate dev --name init_council
#                        npx prisma generate
#
# IMPORTANT (Vercel): set SESSION_STORE=prisma in production. Each serverless
# invocation is a fresh isolate, so the in-memory store cannot serve the
# poll-for-status flow across invocations. See docs/24_deployment_vercel_neon.md.
SESSION_STORE=memory

# ───────────────────────────────────────────────────────────────
# Admin / observability
# ───────────────────────────────────────────────────────────────
# Shared secret for the developer/admin debug payload on
#   GET /api/council-sessions/:id?debug=1
# If set, the caller MUST send `x-admin-debug-token: <this value>`.
# If unset, ?debug=1 is allowed ONLY when NODE_ENV !== "production".
# Always set this before exposing the API outside a trusted network.
# ADMIN_DEBUG_TOKEN="generate-a-long-random-string"

# Optional shared secret for MUTATING (write) endpoints:
#   POST /api/council-sessions, /api/council-sessions/:id/start,
#   POST /api/documents, /api/documents/parse, /api/documents/blob/upload
# If set, callers MUST send `x-api-write-token: <this value>`; otherwise writes
# are OPEN (local / MVP). Lightweight stopgap — replace with real auth/RBAC at
# deployment. Read (GET) endpoints are not gated by this token.
# API_WRITE_TOKEN="generate-a-long-random-string"

# ───────────────────────────────────────────────────────────────
# External official-source fetch (internal_docs_web, docs/23)
# ───────────────────────────────────────────────────────────────
# When a session uses evidenceMode=internal_docs_web, user-provided official
# URLs are fetched SERVER-SIDE as a side-car (never halts the council run).
# Trust level per domain comes from the whitelist in
#   apps/web/src/lib/council/sourceWhitelist.ts
# (anything not listed → unverified_web, not business-citable). No retries.
SOURCE_FETCH_TIMEOUT_MS=8000
EVIDENCE_RETRIEVAL_BUDGET_MS=20000
MAX_SOURCES_PER_SESSION=6
MAX_PARALLEL_SOURCE_FETCH=3

# ───────────────────────────────────────────────────────────────
# Real-provider smoke tests (opt-in, costs real API quota)
# ───────────────────────────────────────────────────────────────
# When true, real_provider_smoke.test.ts will hit each configured provider
# once to validate model policy, schema handling, and abort plumbing.
# Per-provider tests skip cleanly when the corresponding API key is absent.
# REAL_PROVIDER_SMOKE=false

# ───────────────────────────────────────────────────────────────
# Per-provider rate-limit / concurrency policy
# ───────────────────────────────────────────────────────────────
# Each provider has its own limiter so a hot Gemini quota does not stall
# Claude or GPT. When a provider trips its cooldown the orchestrator marks it
# rate_limited and continues the session with the remaining providers.

# OpenAI
RATE_LIMIT_OPENAI_MAX_CONCURRENT=2
RATE_LIMIT_OPENAI_BACKOFF_MAX_MS=8000
RATE_LIMIT_OPENAI_MAX_RETRIES=2
RATE_LIMIT_OPENAI_COOLDOWN_MS=30000

# Anthropic
RATE_LIMIT_ANTHROPIC_MAX_CONCURRENT=2
RATE_LIMIT_ANTHROPIC_BACKOFF_MAX_MS=8000
RATE_LIMIT_ANTHROPIC_MAX_RETRIES=2
RATE_LIMIT_ANTHROPIC_COOLDOWN_MS=30000

# Gemini
RATE_LIMIT_GEMINI_MAX_CONCURRENT=2
RATE_LIMIT_GEMINI_BACKOFF_MAX_MS=8000
RATE_LIMIT_GEMINI_MAX_RETRIES=2
RATE_LIMIT_GEMINI_COOLDOWN_MS=30000
